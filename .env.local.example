# Copia questo file come .env.local e compila i valori

# PostgreSQL (cambia user/password/nome_db con i tuoi)
DATABASE_URL="postgresql://postgres:password@localhost:5432/metalmontaggi"

# JWT Secret (generane uno casuale: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET="cambia-questa-stringa-con-un-valore-segreto-lungo-e-casuale"

# URL del sito in produzione (opzionale)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

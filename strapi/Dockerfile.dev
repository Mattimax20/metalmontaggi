# ============================================================
#  Strapi Development Image (hot-reload)
# ============================================================
FROM node:18-alpine

RUN apk add --no-cache \
    libc6-compat \
    python3 \
    make \
    g++ \
    vips-dev

WORKDIR /opt/app

COPY package.json package-lock.json* ./
RUN npm install

COPY . .

RUN mkdir -p public/uploads

EXPOSE 1337

CMD ["npm", "run", "develop"]

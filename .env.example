# ============================================================
#  Metal Montaggi — Strapi CMS — Variabili d'Ambiente
#  Copia questo file in .env e personalizza i valori
# ============================================================

# ---- Database PostgreSQL ----
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=metalmontaggi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=StrongPassword123!
DATABASE_SSL=false

# ---- Strapi Secrets (genera valori casuali con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
APP_KEYS=key1base64==,key2base64==,key3base64==,key4base64==
API_TOKEN_SALT=saltbase64value==
ADMIN_JWT_SECRET=adminJwtSecretBase64==
JWT_SECRET=jwtSecretBase64==
TRANSFER_TOKEN_SALT=transferTokenSaltBase64==

# ---- Admin iniziale (creato automaticamente al primo avvio) ----
ADMIN_EMAIL=admin@metalmontaggi.it
ADMIN_PASSWORD=MetalMontaggi@2024!

# ---- Server ----
HOST=0.0.0.0
PORT=1337
NODE_ENV=production

# ---- Upload ----
UPLOAD_MAX_SIZE=104857600
